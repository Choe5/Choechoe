<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外層發光暈（藍色，用 animator 控制 alpha 閃爍） -->
    <item
        android:left="-4dp"
        android:top="-4dp"
        android:right="-4dp"
        android:bottom="-4dp">
        <shape android:shape="rectangle">
            <solid android:color="#0000BFFF" />
            <corners android:radius="22dp" />
            <stroke android:width="6dp" android:color="#AA00BFFF" />
        </shape>
    </item>
    <!-- 主體深藍背景 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#EE0D1B3D" />
            <corners android:radius="18dp" />
            <stroke android:width="2dp" android:color="#FF00BFFF" />
        </shape>
    </item>
</layer-list>
