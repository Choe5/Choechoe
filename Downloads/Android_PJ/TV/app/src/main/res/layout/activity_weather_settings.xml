<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 毛玻璃背景 -->
    <ImageView
        android:id="@+id/ivFrostedBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- 暗色遮罩 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <!-- 主內容 -->
    <LinearLayout
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical">

        <!-- 標題 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="天氣設置"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp" />

        <!-- 設定卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_frosted_card"
            android:padding="4dp">

            <!-- 桌面顯示天氣 開關 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="桌面顯示天氣"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnShowWeather"
                    android:layout_width="80dp"
                    android:layout_height="40dp"
                    android:text="開啟"
                    android:textColor="#FFFFFFFF"
                    android:background="@drawable/bg_toggle_btn"
                    android:textSize="13sp"
                    android:focusable="true" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#44FFFFFF" />

            <!-- 城市地點 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="城市地點"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/etCity"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:hint="例：Taipei"
                    android:textColor="#FFFFFFFF"
                    android:textColorHint="#66FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/bg_edit_text"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="text"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#44FFFFFF" />

            <!-- API Key -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="API Key"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/etApiKey"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:hint="OpenWeatherMap API Key"
                    android:textColor="#FFFFFFFF"
                    android:textColorHint="#66FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/bg_edit_text"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="textPassword"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#44FFFFFF" />

            <!-- 儲存按鈕 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <Button
                    android:id="@+id/btnSaveWeather"
                    android:layout_width="200dp"
                    android:layout_height="42dp"
                    android:text="儲存天氣設定"
                    android:textColor="#FFFFFFFF"
                    android:background="@drawable/bg_apply_btn"
                    android:textSize="14sp"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
