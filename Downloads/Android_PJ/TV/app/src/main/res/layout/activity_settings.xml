<?xml version="1.0" encoding="utf-8"?>
<!--
    設定樞紐頁 — 5 個彩色圓形選單
    Z-Order（由下至上）：
    1. ImageView  — 毛玻璃（低解析度桌布）
    2. View       — 暗色遮罩
    3. 5 圓形 Icon 橫排（焦點才顯示文字）
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- 毛玻璃背景（由 Activity 以低解析度載入桌布） -->
    <ImageView
        android:id="@+id/ivFrostedBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- 暗色霧化遮罩 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <!-- 5 圓形圖示橫排，垂直置中 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- 1. 時間設置（紅） -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:clipChildren="false"
            android:clipToPadding="false">

            <FrameLayout
                android:id="@+id/circleTime"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_circle_red"
                android:focusable="true"
                android:clickable="true"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="時"
                    android:textColor="#FFFFFFFF"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium" />
            </FrameLayout>

            <TextView
                android:id="@+id/labelTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="時間設置"
                android:textColor="#FFFFFFFF"
                android:textSize="19sp"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- 2. 天氣設置（橙） -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:clipChildren="false"
            android:clipToPadding="false">

            <FrameLayout
                android:id="@+id/circleWeather"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_circle_orange"
                android:focusable="true"
                android:clickable="true"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="天"
                    android:textColor="#FFFFFFFF"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium" />
            </FrameLayout>

            <TextView
                android:id="@+id/labelWeather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="天氣設置"
                android:textColor="#FFFFFFFF"
                android:textSize="19sp"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- 3. 桌布設置（藍） -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:clipChildren="false"
            android:clipToPadding="false">

            <FrameLayout
                android:id="@+id/circleWallpaper"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_circle_blue"
                android:focusable="true"
                android:clickable="true"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="壁"
                    android:textColor="#FFFFFFFF"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium" />
            </FrameLayout>

            <TextView
                android:id="@+id/labelWallpaper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="桌布設置"
                android:textColor="#FFFFFFFF"
                android:textSize="19sp"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- 4. 其他設置（綠） -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:clipChildren="false"
            android:clipToPadding="false">

            <FrameLayout
                android:id="@+id/circleOther"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_circle_green"
                android:focusable="true"
                android:clickable="true"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="設"
                    android:textColor="#FFFFFFFF"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium" />
            </FrameLayout>

            <TextView
                android:id="@+id/labelOther"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="其他設置"
                android:textColor="#FFFFFFFF"
                android:textSize="19sp"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- 5. 關於（黃） -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:clipChildren="false"
            android:clipToPadding="false">

            <FrameLayout
                android:id="@+id/circleAbout"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_circle_yellow"
                android:focusable="true"
                android:clickable="true"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="於"
                    android:textColor="#222222"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium" />
            </FrameLayout>

            <TextView
                android:id="@+id/labelAbout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="關於"
                android:textColor="#FFFFFFFF"
                android:textSize="19sp"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
