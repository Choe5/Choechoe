<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:clickable="true"
    android:foreground="@drawable/bg_wallpaper_item_focus"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_wallpaper_item"
        android:elevation="4dp"
        android:clipToOutline="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp">

            <ImageView
                android:id="@+id/ivWallpaperThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_wallpaper" />

            <TextView
                android:id="@+id/ivVideoIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:text="▶"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/bg_wallpaper"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/ivCheckmark"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="✓"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@drawable/bg_checkmark"
                android:elevation="2dp"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvWallpaperLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="預設"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:paddingHorizontal="4dp"
            android:paddingVertical="8dp"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true" />

    </LinearLayout>
</FrameLayout>